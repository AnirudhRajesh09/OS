#include<stdio.h>
#include<stdlib.h>
#include<limits.h>

int main()
{
    int n, a[50];
    printf("Enter the no. of array elements: ");
    scanf("%d", &n);

    if (n < 2) {
        printf("Array needs at least two elements.\n");
        return 1;
    }

    printf("\nEnter the values:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    int smallest = INT_MAX;
    int sec_small = INT_MAX;

    for (int i = 0; i < n; i++) {
        if (a[i] < smallest) {
            sec_small = smallest;
            smallest = a[i];
        } else if (a[i] < sec_small && a[i] != smallest) {
            sec_small = a[i];
        }
    }

    if (sec_small == INT_MAX) {
        printf("\nThere is no second smallest element (all elements are the same).");
    } else {
        printf("\nSmallest is %d", smallest);
        printf("\nSecond smallest is %d", sec_small);
    }

    return 0;
}
