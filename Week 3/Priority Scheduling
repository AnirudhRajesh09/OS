#include <stdio.h>
#include <stdlib.h>

#define MAX 20

// Function for Non-Preemptive Priority Scheduling
void priority_np(int n, int at[], int bt[], int pr[]) {
    int wt[MAX], tat[MAX], ct[MAX], rt[MAX];
    int done[MAX] = {0};
    int time = 0, count = 0;
    float sw = 0, st = 0;

    while (count < n) {
        int idx = -1, min = 9999;

        for (int i = 0; i < n; i++) {
            if (at[i] <= time && done[i] == 0 && pr[i] < min) {
                min = pr[i];
                idx = i;
            }
        }

        if (idx != -1) {
            rt[idx] = time - at[idx];
            wt[idx] = time - at[idx];
            time += bt[idx];
            ct[idx] = time;
            tat[idx] = ct[idx] - at[idx];
            done[idx] = 1;
            count++;
        } else {
            time++;
        }
    }

    printf("\nPID\tAT\tBT\tPR\tCT\tWT\tTAT\tRT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\t%d\n", i + 1, at[i], bt[i], pr[i], ct[i], wt[i], tat[i], rt[i]);
        sw += wt[i];
        st += tat[i];
    }
    printf("\nAverage WT = %.2f", sw / n);
    printf("\nAverage TAT = %.2f\n", st / n);
}

// Function for Preemptive Priority Scheduling
void priority_p(int n, int at[], int bt[], int pr[]) {
    int rt_bt[MAX], wt[MAX], tat[MAX], ct[MAX], rt[MAX];
    int first[MAX] = {0};
    int complete = 0, time = 0;
    float sw = 0, st = 0;

    for (int i = 0; i < n; i++) {
        rt_bt[i] = bt[i]; // Copy burst times to remaining burst times
    }

    while (complete < n) {
        int idx = -1, min = 9999;

        for (int i = 0; i < n; i++) {
            if (at[i] <= time && rt_bt[i] > 0 && pr[i] < min) {
                min = pr[i];
                idx = i;
            }
        }

        if (idx != -1) {
            if (first[idx] == 0) {
                rt[idx] = time - at[idx];
                first[idx] = 1;
            }
            rt_bt[idx]--;
            time++;

            if (rt_bt[idx] == 0) {
                complete++;
                ct[idx] = time;
                tat[idx] = ct[idx] - at[idx];
                wt[idx] = tat[idx] - bt[idx];
            }
        } else {
            time++;
        }
    }

    printf("\nPID\tAT\tBT\tPR\tCT\tWT\tTAT\tRT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\t%d\n", i + 1, at[i], bt[i], pr[i], ct[i], wt[i], tat[i], rt[i]);
        sw += wt[i];
        st += tat[i];
    }
    printf("\nAverage WT = %.2f", sw / n);
    printf("\nAverage TAT = %.2f\n", st / n);
}

int main() {
    int n, choice;
    int at[MAX], bt[MAX], pr[MAX];

    printf("Enter no. of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter AT, BT, and Priority for PID %d: ", i + 1);
        scanf("%d %d %d", &at[i], &bt[i], &pr[i]);
    }

    printf("\n1. Priority Non-Preemptive\n2. Priority Preemptive\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            priority_np(n, at, bt, pr);
            break;
        case 2:
            priority_p(n, at, bt, pr);
            break;
        default:
            printf("Invalid Choice\n");
    }

    return 0;
}
